/* nvm_map.def
*
* NVM_FIELD(name, DPL_LIST, DPL_VALUE, CNTRL_VALUE)
*
* DPL_VALUE: datapool global variable
* CNTRL_VALUE: control structure varialbe
*/

/* Elevator Control Parameters */
NVM_FIELD(elevatorMinSpeed, CONFIGURATION_LIST_INDEX_ELEVATORCONFIG, gt_Configuration_DataPoolValues.t_ElevatorConfigValues.u8_minSpeed, gt_elevatorConfig.u8_minSpeed)
NVM_FIELD(elevatorMaxSpeed, CONFIGURATION_LIST_INDEX_ELEVATORCONFIG, gt_Configuration_DataPoolValues.t_ElevatorConfigValues.u8_maxSpeed, gt_elevatorConfig.u8_maxSpeed)

/* Sweeper Control Parameters */
NVM_FIELD(sweeperMinRPM, CONFIGURATION_LIST_INDEX_SWEEPERCONFIG, gt_Configuration_DataPoolValues.t_SweeperConfigValues.s16_minRPM, gt_sweeperConfig.s16_minRPM)
NVM_FIELD(sweeperMaxRPM, CONFIGURATION_LIST_INDEX_SWEEPERCONFIG, gt_Configuration_DataPoolValues.t_SweeperConfigValues.s16_maxRPM, gt_sweeperConfig.s16_maxRPM)

/* Boom Control Parameters */
NVM_FIELD(boomInvertRocker, CONFIGURATION_LIST_INDEX_BOOMCONFIG, gt_Configuration_DataPoolValues.t_BoomConfigValues.u8_invertRocker, gt_boomConfig.u8_invertRocker)