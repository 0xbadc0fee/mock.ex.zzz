/* can_in_map.def
*
* DP2CNTRL(name, CNTRL_VAL, DPL_VALUE)
*
* DEST_VALUE: expression that can be assigned into (control variable)
* SRC_VALUE: expression that yields the value to assign (from datapool)
*/

/* Elevator Control CAN Parameters */
/*DP2CNTRL(elevatorSpeed, gt_ui.t_display.u8_elevatorSpeedRequest, gt_J1939_DataPoolValues.t_CAN1_RXValues.u8_DISP_CAN_Rec1_AgvHmiElevatorSpeedCmd)*/
DP2CNTRL(elevatorOnOff, gt_ui.t_joystick.u8_b1_state, gt_J1939_DataPoolValues.t_CAN1_RXValues.u8_BJM1_Joystick1Button1PressedStatus)

/* Boom Lift - Lower */
DP2CNTRL(boomLift, gt_joystickJSLX.u8_b2_state, gt_J1939_DataPoolValues.t_CAN1_RXValues.u8_BJM1_Joystick1Button2PressedStatus)
DB2CNTRL(boomLower, gt_joystickJSLX.u8_b3_state, gt_J1939_DataPoolValues.t_CAN1_RXValues.u8_BJM1_Joystick1Button3PressedStatus)