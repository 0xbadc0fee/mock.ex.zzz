/* can_in_map.def
*
* DP2CNTRL(name, CNTRL_VAL, DPL_VALUE)
*
* DEST_VALUE: expression that can be assigned into (control variable)
* SRC_VALUE: expression that yields the value to assign (from datapool)
*/

/* Boom Lift-Lower CAN Signals*/
DP2CNTRL(boomLift,      gt_can_devs.t_joystickJSLX.u8_b3_state,     gt_J1939_DataPoolValues.t_CAN1_RXValues.u8_BJM1_Joystick1Button2PressedStatus)
DP2CNTRL(boomLower,     gt_can_devs.t_joystickJSLX.u8_b2_state,     gt_J1939_DataPoolValues.t_CAN1_RXValues.u8_BJM1_Joystick1Button3PressedStatus)

/* Engine RPM from EEC1 */
DP2CNTRL(engineSpeed,   gt_can_devs.t_engine.u16_engineSpeed,        gt_J1939_DataPoolValues.t_CAN1_RXValues.u16_EEC1_EngSpeed)