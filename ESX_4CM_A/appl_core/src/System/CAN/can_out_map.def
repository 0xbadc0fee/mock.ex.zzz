/* can_out_map.def
*
* CNTRL2DP(name, DPL_VALUE, CNTRL_VALUE)
*
* DP_LVALUE: expression that can be assigned into (datapool global field)
* SRC_RVALUE: expression that yields the value to assign (from control structs)
*/

